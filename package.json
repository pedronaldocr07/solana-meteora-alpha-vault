{
  "name": "solana-meteora-alpha-vault-bundler",
  "version": "0.1.0",
  "description": "Multi-wallet Jito bundler for Meteora Alpha Vault deposits, claims and withdrawals on Solana.",
  "main": "dist/index.js",
  "bin": {
    "alpha-bundler": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node --transpile-only src/index.ts",
    "deposit": "ts-node --transpile-only src/index.ts deposit",
    "claim": "ts-node --transpile-only src/index.ts claim",
    "withdraw": "ts-node --transpile-only src/index.ts withdraw",
    "status": "ts-node --transpile-only src/index.ts status",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "solana",
    "meteora",
    "alpha-vault",
    "jito",
    "bundler",
    "fair-launch",
    "defi"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.29.0",
    "@meteora-ag/alpha-vault": "^1.1.7",
    "@solana/spl-token": "^0.4.6",
    "@solana/web3.js": "^1.95.3",
    "axios": "^1.7.7",
    "bn.js": "^5.2.1",
    "bs58": "^5.0.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "p-limit": "^3.1.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.5",
    "@types/node": "^20.14.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  }
}
