# --- Solana ---
RPC_URL=https://api.mainnet-beta.solana.com
# Optional dedicated RPC for sending (a fast staked or paid endpoint is recommended)
SEND_RPC_URL=

# --- Meteora Alpha Vault ---
# Public key of the Alpha Vault account you want to interact with
ALPHA_VAULT_ADDRESS=

# --- Wallets ---
# Path to a JSON file containing the private keys to bundle from
WALLETS_FILE=./wallets.json

# --- Deposit sizing ---
# Either set a fixed per-wallet deposit (in deposit-token units, e.g. USDC),
# or set TOTAL_DEPOSIT to be split evenly across wallets.
PER_WALLET_DEPOSIT=
TOTAL_DEPOSIT=

# --- Jito ---
# Jito Block Engine region URL. Choose the closest one to your RPC.
# Examples:
#   https://mainnet.block-engine.jito.wtf
#   https://amsterdam.mainnet.block-engine.jito.wtf
#   https://frankfurt.mainnet.block-engine.jito.wtf
#   https://ny.mainnet.block-engine.jito.wtf
#   https://tokyo.mainnet.block-engine.jito.wtf
JITO_BLOCK_ENGINE=https://mainnet.block-engine.jito.wtf

# Tip in lamports to pay the Jito validator (default: 100_000 = 0.0001 SOL)
JITO_TIP_LAMPORTS=100000

# Index of the wallet (0-based) that pays the Jito tip; if empty, the first wallet pays
JITO_TIPPER_INDEX=0

# --- Tx sizing ---
# Compute unit price in micro-lamports for priority fee
PRIORITY_FEE_MICROLAMPORTS=50000
COMPUTE_UNIT_LIMIT=400000

# --- Behavior ---
# Dry-run prints the bundle but does not submit it
DRY_RUN=false
